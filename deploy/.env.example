# ════════════════════════════════════════════════════════════════
#  Adil Smart Store — Variables d'environnement Hostinger
#  Ces variables se configurent dans hPanel → Node.js → Env Variables
#  NE PAS uploader ce fichier tel quel sur le serveur
# ════════════════════════════════════════════════════════════════

# Environnement (ne pas changer)
NODE_ENV=production

# Port — Hostinger le fixe automatiquement, ne pas modifier
PORT=3000

# ─── Base de données PostgreSQL ─────────────────────────────────
# Créez une base de données gratuite sur https://neon.tech
# Puis copiez la "Connection string" ici.
# Format : postgresql://USER:PASS@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://UTILISATEUR:MOT_DE_PASSE@HOTE/NOM_BDD?sslmode=require

# ─── Admin Dashboard ────────────────────────────────────────────
# Mot de passe pour accéder à /admin
ADMIN_PASSWORD=adil2024
