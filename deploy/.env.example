# ══════════════════════════════════════════════════════════════
#  Adil Smart Store — Variables d'environnement
#  Copiez ce fichier en .env et remplissez les valeurs
# ══════════════════════════════════════════════════════════════

# Environnement (ne pas changer)
NODE_ENV=production

# Port du serveur Node.js (ne pas changer si vous utilisez Nginx)
PORT=3000

# ─── Base de données PostgreSQL ────────────────────────────────
# Format : postgresql://UTILISATEUR:MOT_DE_PASSE@HOTE:PORT/NOM_BDD
# Exemple Hostinger VPS :
#   postgresql://adilstore_user:MonMotDePasse123@localhost:5432/adilstore_db
DATABASE_URL=postgresql://UTILISATEUR:MOT_DE_PASSE@localhost:5432/NOM_BDD

# ─── Session ──────────────────────────────────────────────────
# Chaîne aléatoire longue pour sécuriser les sessions
# Générez-en une avec : openssl rand -base64 32
SESSION_SECRET=changez-cette-valeur-par-une-chaine-aleatoire-longue

# ─── Admin Dashboard ──────────────────────────────────────────
# Mot de passe de l'interface d'administration (/admin)
ADMIN_PASSWORD=adil2024
